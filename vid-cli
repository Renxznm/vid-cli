#!/bin/bash
# vid-cli: Minimalist YouTube Search & Play
# Author: Renxznm
# Target: Arch User Repository (AUR)

version_number="4.0.0"

# --- CORE FUNCTIONS ---

# Display error message(if there any) and exit(inspired by ani-cli)
die() {
    printf "\033[1;31m%s\033[0m\n" "$*" >&2
    exit 1
}

# Check if required dependencies are installed
check_dependencies() {
    for dep in "$@"; do
        command -v "$dep" >/dev/null 2>&1 || die "Error: '$dep' is not installed. Please install it first."
    done
}

# Modular fzf
launcher() {
    fzf --prompt="$1" --border=rounded --layout=reverse --height="$2"
}

# Display help menu
help_info() {
    printf "🎬 \033[1;36mvid-cli\033[0m v%s - Minimalist YouTube Player Inspired by ani-cli\n\n" "$version_number"
    printf "Usage:\n  vid-cli [query]\n  vid-cli [options]\n\n"
    printf "Options:\n"
    printf "  -v, --version    Show script version\n"
    printf "  -h, --help       Show this help message\n\n"
    printf "Example:\n  vid-cli \"wemmbu 2 pro vs 1000\"\n"
    exit 0
}

# --- 1. SETUP & ARGUMENTS ---

# dependency check before running anything
check_dependencies "yt-dlp" "fzf" "mpv" "awk" "ffmpeg"

query="$1"

# Handle flags (-v, -h)
case "$query" in
    -v|--version) echo "vid-cli v$version_number"; exit 0 ;;
    -h|--help) help_info ;;
esac

# exit prompt if no query is provided
if [ -z "$query" ]; then
    read -p "Search video: " query
    [ -z "$query" ] && die "Error: Search query cannot be empty."
fi

echo -e "🔍 Searching for '\033[1;33m$query\033[0m'..."

# --- 2. SEARCH & SELECT LOGIC ---

# --flat-playlist: avoiding metadata extraction so it goes swhosh
selected=$(yt-dlp "ytsearch50:$query" --flat-playlist --print "%(title)s :: %(uploader)s :: %(id)s" 2>/dev/null | launcher "📺 Select Video: " "80%" --delimiter=" :: " --with-nth=1,2)

[ -z "$selected" ] && { echo "❌ Cancelled."; exit 0; }

# Extract the hidden Video ID (the last field separated by ' :: ')
video_id=$(echo "$selected" | awk -F ' :: ' '{print $NF}')

# --- 3. RESOLUTION SELECTOR ---

echo "⚙️  Select Video Quality:"
quality=$(printf "1. 1080p (FHD)\n2. 720p (HD)\n3. 480p (SD)\n4. 360p (Low)\n5. Best Available" | launcher "📺 Quality: " "10")

[ -z "$quality" ] && { echo "❌ Cancelled."; exit 0; }

# Map user choice to yt-dlp format strings
case "$quality" in
    *1080p*) format="bestvideo[height<=1080]+bestaudio/best" ;;
    *720p*)  format="bestvideo[height<=720]+bestaudio/best"  ;;
    *480p*)  format="bestvideo[height<=480]+bestaudio/best"  ;;
    *360p*)  format="bestvideo[height<=360]+bestaudio/best"  ;;
    *)       format="bestvideo+bestaudio/best" ;;
esac

echo -e "🚀 Starting stream via \033[1;32mmpv\033[0m..."

# --- 4. EXECUTION LOGIC ---

# ffmpeg is required to merge the 1080p video stream with the best audio stream.
mpv --ytdl-format="$format" --hwdec=auto-safe "https://www.youtube.com/watch?v=$video_id" >/dev/null 2>&1 #>/dev/null to hide error that idgaf and doesnt broke anything

echo "✅ Playback finished."
